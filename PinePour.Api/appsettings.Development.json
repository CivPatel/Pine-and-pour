    // Set via environment variable ConnectionStrings__DataContext for local dev
    // Example: Host=localhost;Port=5432;Database=pinepour;Username=postgres;Password=<password>
    "DataContext": ""
  },
  "Stripe": {
    "SecretKey": ""
  }
}
