{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Spa": {
    "DevServerUrl": "http://localhost:5173"
  },

  "Database": {
    // Options: SqlServer | Postgres
    "Provider": "Postgres"
  },

  "Stripe": {
    // Set via environment variable Stripe__SecretKey
    "SecretKey": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    // Set via environment variable ConnectionStrings__DataContext
    // (e.g. on Render; do not commit real credentials)
    //
    // For Supabase + Render (IPv4-only), use the Supabase "Session pooler" connection string
    // from the Supabase Dashboard (Connect -> Session pooler).
    //
    // Example (DO NOT COMMIT REAL PASSWORDS):
    // Host=aws-0-<region>.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.<project-ref>;Password=<password>;SSL Mode=Require;Trust Server Certificate=true
    "DataContext": ""
  }
}
